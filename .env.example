# === NOAA Weather API ===
# Your email as User-Agent (required by NOAA)
NOAA_USER_AGENT=your-email@example.com

# === Polymarket ===
# CLOB API credentials (get from https://docs.polymarket.com)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
# Ethereum private key for signing trades (use a dedicated trading wallet!)
POLYMARKET_PRIVATE_KEY=

# === Trading Parameters ===
# true = simulate trades without executing, false = live trading
DRY_RUN=true
# Maximum single bet in USDC
MAX_BET_SIZE=20
# Total bankroll in USDC
BANKROLL=500
# Minimum edge threshold (0.15 = 15%)
MIN_EDGE=0.15
# Cron schedule (default: every 30 minutes)
CRON_SCHEDULE=*/30 * * * *

# === Telegram Notifications ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Logging ===
LOG_LEVEL=info
